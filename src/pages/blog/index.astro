---
/**
 * blog/index.astro
 *
 * Listagem do blog - exibe posts publicados.
 * Usa layout conforme siteMode: local → LocalLayout (header/footer do modo local), blog → MainLayout.
 */

import { getCollection, getEntry } from 'astro:content';
import BlogList from '../../themes/classic/BlogList.astro';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteMode = settings?.data?.siteMode || 'blog';
const layoutType = siteMode === 'local' ? 'local' : 'main';

const allPosts = await getCollection('posts');
const publishedPosts = allPosts
    .filter(post => post.data.publishedDate)
    .sort((a, b) => new Date(b.data.publishedDate!).getTime() - new Date(a.data.publishedDate!).getTime());
---

<BlogList
    posts={publishedPosts}
    themeId="classic"
    layoutType={layoutType}
/>
